# ============================================================================
# Pepta - Vite React SPA .htaccess for Hostinger (Apache)
# ============================================================================
# CRITICAL: This fixes "not showing updated version" after deployment.
#
# Why this is needed:
#   - Vite React is a Single Page App — there is only ONE index.html
#   - If Apache/Hostinger caches index.html, users see OLD versions forever
#   - JS/CSS files are SAFE to cache because Vite gives them hashed filenames
#     (e.g. index.abc123.js) — a new deploy = a new filename = forced update
# ============================================================================

Options -MultiViews
RewriteEngine On

# ─── SPA Routing: redirect all routes to index.html ──────────────────────────
# This allows React Router to handle /products, /products/123, etc.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]

# ─── NEVER cache index.html ──────────────────────────────────────────────────
# This is the single most important rule for a Vite React SPA.
# Every time you deploy, users MUST get the new index.html.
<FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# ─── NEVER cache the manifest or service worker ──────────────────────────────
<FilesMatch "\.(webmanifest|json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
<FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# ─── Cache hashed JS/CSS/fonts FOREVER (safe — Vite changes the filename) ───
<FilesMatch "\.(js|css|woff2|woff|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# ─── Cache images for 30 days ─────────────────────────────────────────────────
<FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# ─── Security Headers ─────────────────────────────────────────────────────────
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
