# Vercel Ignore File
# Files/directories that should not be deployed to Vercel

# Dependencies
node_modules/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store

# Environment (sensitive files)
.env
.env.local
.env.*.local

# Build files (Vercel will rebuild)
.next/
out/
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Documentation
README.md
DEPLOYMENT_CHECKLIST.md
*.md

# System files
.vercel/
.turbo/
